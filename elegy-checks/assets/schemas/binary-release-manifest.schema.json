{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy.dev/schemas/elegy-checks-binary-release-manifest.schema.json",
  "title": "Elegy Checks Binary Release Manifest",
  "type": "object",
  "required": ["schemaVersion", "name", "version", "artifacts"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "name": { "const": "elegy-checks" },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "sourceCommit": { "type": "string" },
    "publishedAt": { "type": "string" },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["platform", "url", "sha256"],
        "properties": {
          "platform": {
            "enum": ["windows-x64", "linux-x64", "darwin-x64", "darwin-arm64"]
          },
          "url": { "type": "string" },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "sizeBytes": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
