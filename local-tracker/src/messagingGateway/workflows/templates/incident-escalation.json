{
  "id": "incident-escalation",
  "name": "Incident Escalation",
  "description": "Escalates an incident by collecting diagnostics, notifying team, and creating incident record.",
  "version": "1.0.0",
  "steps": [
    {
      "id": "collect-diagnostics",
      "name": "Collect Diagnostics",
      "action": "diagnostics.collect",
      "params": { "depth": "full" }
    },
    {
      "id": "create-incident",
      "name": "Create Incident Record",
      "action": "incident.create",
      "dependsOn": ["collect-diagnostics"]
    },
    {
      "id": "notify-team",
      "name": "Notify Team",
      "action": "notify.team",
      "params": { "channel": "incident" },
      "dependsOn": ["collect-diagnostics"]
    },
    {
      "id": "await-response",
      "name": "Await Team Response",
      "action": "incident.awaitResponse",
      "params": { "timeoutMs": 300000 },
      "dependsOn": ["notify-team", "create-incident"]
    }
  ]
}
