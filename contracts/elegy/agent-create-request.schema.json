{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/agent-create-request.schema.json",
  "title": "Agent Create Request",
  "description": "Request to create a new agent via the AgentFactory service.",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Kebab-case agent name."
    },
    "description": {
      "type": "string",
      "description": "Optional human-readable description of the agent."
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capabilityId", "name"],
        "additionalProperties": false,
        "properties": {
          "capabilityId": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "description": "Capabilities this agent supports."
    },
    "routingRules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ruleId", "pattern", "priority", "targetCapabilityId"],
        "additionalProperties": false,
        "properties": {
          "ruleId": { "type": "string" },
          "pattern": { "type": "string" },
          "priority": { "type": "integer" },
          "targetCapabilityId": { "type": "string" }
        }
      },
      "description": "Rules for routing requests to capabilities."
    },
    "scope": {
      "type": "string",
      "enum": ["Session", "Workspace", "Global"],
      "default": "Session",
      "description": "Scope of the agent: Session, Workspace, or Global."
    }
  }
}
