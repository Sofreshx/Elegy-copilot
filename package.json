{
  "name": "@elegy-copilot/root",
  "version": "0.0.0",
  "private": true,
  "description": "Elegy Copilot monorepo root",
  "license": "MIT",
  "workspaces": [
    "contracts",
    "copilot-ui",
    "local-repo-mcp",
    "local-tracker",
    "scripts"
  ],
  "scripts": {
    "postinstall": "npm run build:contracts",
    "build:contracts": "npm run build --workspace=contracts",
    "contracts:validate:session-state-sample": "node scripts/validate-session-state-canonical.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:check:links": "node scripts/check-docs-dead-links.mjs",
    "validate:guidelines-wiring": "node scripts/validate-guidelines-wiring.mjs",
    "validate:instruction-wiring": "node scripts/validate-instruction-wiring.mjs",
    "validate:instruction-quality": "node scripts/validate-instruction-quality.mjs",
    "validate:instruction-budgets": "node scripts/validate-instruction-budgets.mjs",
    "validate:skills": "node scripts/validate-skills.mjs",
    "obsidian-docs:preflight": "node scripts/obsidian-docs-preflight.js",
    "obsidian-docs:init": "node scripts/obsidian-docs-init.js --with-config",
    "obsidian-docs:validate": "node scripts/obsidian-docs-validate.js",
    "generate:spec-index": "node scripts/generate-spec-index.js",
    "test:all": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "ci:local": "node scripts/validate-ci-lockfiles.js && node scripts/generate-cli-manifest.mjs && node scripts/generate-policy-lockfiles.js && node scripts/validate-policy-lockfiles.js && node scripts/validate-manifest.js && node scripts/validate-doc-graph.js && node scripts/check-docs-dead-links.mjs && node scripts/validate-guidelines-wiring.mjs && npm --prefix copilot-ui run ui:build && npm --prefix local-tracker run build && npm --prefix copilot-ui run tauri:check:linux && npm --prefix copilot-ui run validate:tauri-node-sidecar-layout && node copilot-ui/tests/ui-react-smoke.test.js && node copilot-ui/tests/runtime-startup-contract.test.js && node copilot-ui/lib/repoInventoryService.test.js",
    "ci:local:full": "npm run ci:local && npm --prefix copilot-ui run tauri:check && npm run docs:build",
    "ui:check": "node scripts/ui-check.mjs",
    "ui:check:validate": "node scripts/ui-check.mjs --validate-only",
    "commit-check:discover": "node scripts/commit-check-discover.mjs",
    "commit-check:setup": "node scripts/commit-check-setup.mjs",
    "commit-check:run": "node scripts/commit-check-run.mjs",
    "commit-check": "node scripts/commit-check-run.mjs",
    "build:rust-backend": "cargo build --manifest-path copilot-ui/src-tauri/Cargo.toml",
    "test:rust-backend": "cargo test --manifest-path copilot-ui/src-tauri/Cargo.toml",
    "install:ghcp": "node scripts/ghcp-install.mjs",
    "install:ghcp:dry": "node scripts/ghcp-install.mjs --dry-run",
    "ghcp:profile:switch": "node scripts/ghcp-profile-switch.mjs",
    "ghcp:profile:list": "node scripts/ghcp-profile-switch.mjs --list",
    "ghcp:profile:current": "node scripts/ghcp-profile-switch.mjs --current"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1"
  },
  "devDependencies": {
    "better-sqlite3": "^12.10.0",
    "mermaid": "^11.12.3",
    "undici": "^6.27.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.6",
    "vscode-jsonrpc": "^8.2.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "undici": "$undici",
    "vite": "^6.4.3"
  }
}
