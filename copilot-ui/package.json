{
  "name": "elegy-copilot-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Elegy Copilot desktop app",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "files": [
    "dist-electron",
    "server.js",
    "lib",
    "routes",
    "ui-dist",
    "public",
    "package.json"
  ],
  "scripts": {
    "test": "node scripts/test-with-ledger.js && npm run test:vitest",
    "test:vitest": "vitest run",
    "build:local-tracker": "npm --prefix ../local-tracker run build",
    "build:electron": "npm exec -- tsc -p tsconfig.electron.json",
    "electron:dev": "npm run build:electron && electron .",
    "package:preview": "npm run ui:build && npm run build:local-tracker && npm run build:electron && npm exec -- electron-builder --dir",
    "package:win": "npm run ui:build && npm run build:local-tracker && npm run build:electron && npm exec -- electron-builder --win nsis",
    "smoke:win-updater": "node scripts/desktop-updater-smoke.js",
    "package:win:smoke": "npm run package:win && npm run smoke:win-updater",
    "ui:dev": "vite --config vite.config.ts",
    "ui:build": "vite build --config vite.config.ts",
    "ui:preview": "vite preview --config vite.config.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@github/copilot-sdk": "0.1.9",
    "@elegy-copilot/contracts": "file:../contracts",
    "dompurify": "^3.3.1",
    "electron-updater": "^6.3.9",
    "mermaid": "^11.12.3",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.13.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^2.1.9"
  }
}