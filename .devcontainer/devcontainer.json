{
  "name": "Instruction Engine - Remote Agent",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.preferences.importModuleSpecifier": "relative",
        "github.copilot.enable": {
          "*": true
        }
      }
    },
    "codespaces": {
      "repositories": {
        "Sofreshx/instruction-engine": {
          "permissions": "write-all"
        }
      }
    }
  },
  
  "forwardPorts": [3000, 5173, 8080],
  
  "postCreateCommand": "npm install && npm run build",
  
  "postStartCommand": ".devcontainer/start-agent-session.sh",
  
  "remoteEnv": {
    "SESSION_ID": "${localEnv:SESSION_ID}",
    "AGENT_NAME": "${localEnv:AGENT_NAME}",
    "PROMPT": "${localEnv:PROMPT}",
    "RELAY_WEBHOOK_URL": "${localEnv:RELAY_WEBHOOK_URL}",
    "USER_ID": "${localEnv:USER_ID}"
  },
  
  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb",
    "storage": "16gb"
  },
  
  "waitFor": "postStartCommand"
}
