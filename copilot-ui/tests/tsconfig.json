{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vitest/globals", "node", "@testing-library/jest-dom"],
    "baseUrl": "..",
    "paths": {
      "vitest": ["../node_modules/vitest"],
      "@testing-library/react": ["../node_modules/@testing-library/react"],
      "@testing-library/jest-dom/vitest": ["../node_modules/@testing-library/jest-dom/vitest"]
    }
  },
  "include": [
    "./**/*.vitest.ts",
    "./**/*.vitest.tsx",
    "./vitest.setup.ts"
  ]
}
