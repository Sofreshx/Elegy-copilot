{
  "schemaVersion": "1.1.0",
  "policyVersion": "1.0.0",
  "name": "pipeline-policy",
  "description": "Canonical policy for fail-closed pipeline controls across UI/API/CI/release surfaces.",
  "rules": [
    {
      "id": "ui.block.unsafe-lifecycle-action",
      "severity": "block",
      "scope": "ui",
      "match": {
        "type": "exact",
        "pattern": "lifecycle.action.unauthorized"
      },
      "outcome": {
        "action": "block",
        "message": "Unauthorized lifecycle action requests must fail closed."
      }
    },
    {
      "id": "api.block.invalid-policy-evidence",
      "severity": "block",
      "scope": "api",
      "match": {
        "type": "exact",
        "pattern": "policy.evidence.invalid"
      },
      "outcome": {
        "action": "block",
        "message": "Mutating API routes require valid policy evidence."
      }
    },
    {
      "id": "ci.block.missing-policy-lock",
      "severity": "block",
      "scope": "ci",
      "match": {
        "type": "exact",
        "pattern": "policy.lock.missing"
      },
      "outcome": {
        "action": "block",
        "message": "CI must fail when policy lockfiles are missing or stale."
      }
    },
    {
      "id": "release.block.attestation-mismatch",
      "severity": "block",
      "scope": "release",
      "match": {
        "type": "exact",
        "pattern": "release.attestation.mismatch"
      },
      "outcome": {
        "action": "block",
        "message": "Release promotion requires matching attestation/provenance evidence."
      }
    },
    {
      "id": "agent.block.background-terminal",
      "severity": "block",
      "scope": "agent",
      "match": {
        "type": "hook-rule",
        "pattern": "tool.pre.run_in_terminal"
      },
      "hookConfig": {
        "toolNamePattern": "run_in_terminal",
        "argPatterns": {
          "isBackground": "^true$"
        }
      },
      "outcome": {
        "action": "block",
        "message": "isBackground:true is prohibited per copilot-instructions.md — causes silent failures."
      }
    },
    {
      "id": "agent.warn.destructive-file-delete",
      "severity": "warn",
      "scope": "agent",
      "match": {
        "type": "hook-rule",
        "pattern": "tool.pre.delete_file"
      },
      "hookConfig": {
        "toolNamePattern": "delete_file"
      },
      "outcome": {
        "action": "warn",
        "message": "Destructive file deletion — verify user explicitly requested this."
      }
    }
  ]
}
