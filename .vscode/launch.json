{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "RannIA: Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/RannIA"
			],
			"outFiles": [
				"${workspaceFolder}/RannIA/dist/**/*.js"
			],
			"preLaunchTask": "RannIA: compile"
		}
	]
}
