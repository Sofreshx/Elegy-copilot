# MCP local environment (copy to .env.mcp)
# Keep secrets out of git.

# Supabase (hosted MCP server)
SUPABASE_PROJECT_REF=
SUPABASE_ACCESS_TOKEN=

# Vultr
VULTR_API_KEY=

# Grafana (Loki/Tempo via Grafana proxy)
GRAFANA_API_TOKEN=

# SSH (read-only MCP SSH)
SSH_MCP_HOST=
SSH_MCP_USER=
SSH_MCP_IDENTITY=

# Firebase (optional)
# FIREBASE_TOKEN=
# GOOGLE_APPLICATION_CREDENTIALS=
