{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://instruction-engine.dev/schemas/policy.schema.json",
  "title": "Instruction Engine Pipeline Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "policyVersion",
    "name",
    "rules"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "scope",
          "match",
          "outcome"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warn",
              "block"
            ]
          },
          "scope": {
            "type": "string",
            "enum": [
              "ui",
              "api",
              "ci",
              "release",
              "agent"
            ]
          },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "pattern"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "exact",
                  "glob",
                  "regex",
                  "hook-rule"
                ]
              },
              "pattern": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "outcome": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "action"
            ],
            "properties": {
              "action": {
                "type": "string",
                "enum": [
                  "allow",
                  "warn",
                  "block"
                ]
              },
              "message": {
                "type": "string"
              }
            }
          },
          "hookConfig": {
            "type": "object",
            "additionalProperties": false,
            "required": ["toolNamePattern"],
            "properties": {
              "toolNamePattern": { "type": "string", "minLength": 1 },
              "argPatterns": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        },
        "if": {
          "properties": {
            "match": {
              "properties": {
                "type": { "const": "hook-rule" }
              }
            }
          }
        },
        "then": {
          "required": ["hookConfig"]
        }
      }
    }
  }
}
