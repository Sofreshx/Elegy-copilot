{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "powershell": "./session-start.ps1",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "powershell": "./session-end.ps1",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "powershell": "./log-prompt.ps1",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "powershell": "./pre-tool-use.ps1",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "powershell": "./post-tool-use.ps1",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "powershell": "./error-occurred.ps1",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ]
  }
}
