{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Skill Installer: Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/vscode-skill-installer"
			],
			"outFiles": [
				"${workspaceFolder}/vscode-skill-installer/dist/**/*.js"
			],
			"preLaunchTask": "skill-installer: compile"
		}
	]
}
