{
  "name": "@instruction-engine/root",
  "version": "0.0.0",
  "private": true,
  "description": "Instruction Engine monorepo root",
  "workspaces": [
    "contracts",
    "copilot-ui",
    "local-tracker",
    "RannIA",
    "scripts"
  ],
  "scripts": {
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "postinstall": "npm run build:contracts",
    "build:contracts": "npm run build --workspace=contracts",
    "contracts:sync:elegy": "node scripts/sync-elegy-contracts.js",
    "contracts:validate:elegy-sample": "node scripts/validate-elegy-canonical.js",
    "test:all": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8"
  }
}
