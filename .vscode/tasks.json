{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "RannIA: compile",
			"type": "npm",
			"script": "compile",
			"path": "RannIA",
			"problemMatcher": "$tsc",
			"group": "build"
		},
		{
			"label": "RannIA: watch",
			"type": "npm",
			"script": "watch",
			"path": "RannIA",
			"isBackground": true,
			"problemMatcher": "$tsc-watch",
			"group": "build"
		},
		{
			"label": "RannIA: package",
			"type": "npm",
			"script": "package",
			"path": "RannIA",
			"problemMatcher": []
		},
		{
			"label": "validate: manifest json",
			"type": "shell",
			"command": "node",
			"args": ["scripts/validate-manifest.js"],
			"isBackground": false,
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "validate: docs graph",
			"type": "shell",
			"command": "node",
			"args": ["scripts/validate-doc-graph.js"],
			"isBackground": false,
			"problemMatcher": [],
			"group": "test"
		},
		{
			"label": "validate: plan pack",
			"type": "shell",
			"command": "node",
			"args": ["scripts/validate-planpack.js", "${input:planpackPath}"],
			"isBackground": false,
			"problemMatcher": [],
			"group": "test"
		}
	],
	"inputs": [
		{
			"id": "planpackPath",
			"type": "promptString",
			"description": "Path to plan pack file",
			"default": "plan.md"
		}
	]
}
