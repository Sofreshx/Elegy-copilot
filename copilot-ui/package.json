{
  "name": "instruction-engine-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Instruction Engine desktop wrapper for copilot-ui",
  "main": "dist-electron/main.js",
  "scripts": {
    "test": "node scripts/test-with-ledger.js",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run build:electron && electron .",
    "package:preview": "npm run build:electron && electron-builder --dir",
    "package:win": "npm run build:electron && electron-builder --win nsis",
    "ui:dev": "vite --config vite.config.ts",
    "ui:build": "vite build --config vite.config.ts",
    "ui:preview": "vite preview --config vite.config.ts"
  },
  "dependencies": {
    "@instruction-engine/contracts": "*",
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@types/node": "^22.13.5",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  }
}
