{
  "schemaVersion": 2,
  "platform": "windows",
  "shell": "tauri",
  "status": "windows_release_preview_lane_ready",
  "resourceRoot": ".",
  "releaseLane": {
    "packaging": "windows_nsis_preview_installer",
    "updateMode": "manual_installer",
    "autoUpdateEnabled": false,
    "failClosedChannelPolicy": true
  },
  "nodeRuntime": {
    "relativePath": "node/node.exe",
    "provisioning": "bundle_at_tauri_package_time",
    "hostInstalledNodeAllowed": false
  },
  "entrypoints": {
    "server": "copilot-ui/server.js"
  },
  "resourceCopies": [
    {
      "id": "copilot-ui-server",
      "kind": "file",
      "source": "server.js",
      "target": "copilot-ui/server.js"
    },
    {
      "id": "copilot-ui-lib",
      "kind": "directory",
      "source": "lib",
      "target": "copilot-ui/lib"
    },
    {
      "id": "copilot-ui-routes",
      "kind": "directory",
      "source": "routes",
      "target": "copilot-ui/routes"
    },
    {
      "id": "copilot-ui-ui-dist",
      "kind": "directory",
      "source": "ui-dist",
      "target": "copilot-ui/ui-dist"
    },
    {
      "id": "copilot-ui-package-json",
      "kind": "file",
      "source": "package.json",
      "target": "copilot-ui/package.json"
    },
    {
      "id": "engine-assets",
      "kind": "directory",
      "source": "../engine-assets",
      "target": "engine-assets"
    },
    {
      "id": "cli-policy",
      "kind": "directory",
      "source": "../.cli/policy",
      "target": ".cli/policy",
      "filter": [
        "pipeline-policy.lock.json"
      ]
    },
    {
      "id": "local-tracker-dist",
      "kind": "directory",
      "source": "../local-tracker/dist",
      "target": "local-tracker/dist"
    },
    {
      "id": "local-tracker-node-modules",
      "kind": "directory",
      "source": "../local-tracker/node_modules",
      "target": "local-tracker/node_modules"
    },
    {
      "id": "local-tracker-package-json",
      "kind": "file",
      "source": "../local-tracker/package.json",
      "target": "local-tracker/package.json"
    },
    {
      "id": "scripts",
      "kind": "directory",
      "source": "../scripts",
      "target": "scripts",
      "filter": [
        "cli-*.ps1",
        "cli-*.sh",
        "mcp-env.ps1",
        "mcp-env.sh",
        "validate-policy-lockfiles.js"
      ]
    },
    {
      "id": "moon-bridge-binary",
      "kind": "file",
      "source": "resources/moon-bridge/moon-bridge.exe",
      "target": "moon-bridge/moon-bridge.exe",
      "description": "Bundled Moon Bridge proxy binary for DeepSeek V4 provider routing"
    },
    {
      "id": "runtime-manifests",
      "kind": "directory",
      "source": "resources/runtime-manifests",
      "target": "runtime-manifests",
      "filter": [
        "windows-tauri-node-sidecar.json",
        "default-desktop-rollback-policy.json"
      ]
    }
  ],
  "nodeModulePayload": {
    "manifest": "package.json",
    "sourceRoot": "node_modules",
    "targetRoot": "copilot-ui/node_modules",
    "installStrategy": "production_package_install",
    "requiredRuntimePackages": [
      "@electric-sql/pglite",
      "@elegy-copilot/contracts",
      "@napi-rs/keyring",
      "@photostructure/sqlite-vec",
      "better-sqlite3",
      "eventsource-parser",
      "kimaki",
      "pg",
      "toml"
    ]
  },
  "pglite": {
    "sourceDist": "node_modules/@electric-sql/pglite/dist",
    "targetDist": "copilot-ui/node_modules/@electric-sql/pglite/dist",
    "requiredFiles": [
      "index.cjs",
      "pglite.wasm",
      "pglite.data",
      "initdb.wasm"
    ],
    "mustRemainFilesystemReadable": true
  },
  "nativeRuntimePackageRequirements": {
    "better-sqlite3": {
      "requiredFiles": ["build/Release/better_sqlite3.node"]
    },
    "@napi-rs/keyring": {
      "requiredFiles": [
        {
          "packageName": "@napi-rs/keyring-win32-x64-msvc",
          "path": "keyring.win32-x64-msvc.node"
        }
      ]
    },
    "@photostructure/sqlite-vec": {
      "requiredFiles": ["dist/win32-x64/vec0.dll"]
    }
  },
  "packagingNotes": [
    "The first Windows-first Tauri shell bootstrap resolves localhost runtime assets through the Tauri resource/app-path seam.",
    "The Tauri shell must resolve bundled paths through app resource APIs instead of inferring them from the executable path.",
    "Packaged resources are read-only app assets; mutable runtime state stays rooted under ~/.elegy.",
    "Kimaki runtime state stays under ~/.elegy/kimaki."
  ]
}
