{
  "id": "failed-session-recovery",
  "name": "Failed Session Recovery",
  "description": "Checks a failed session, collects logs, stops the bound session, and launches a separate recovery follow-up.",
  "version": "1.0.0",
  "steps": [
    {
      "id": "check-status",
      "name": "Check Session Status",
      "action": "session.getStatus",
      "params": { "includeErrors": true }
    },
    {
      "id": "collect-logs",
      "name": "Collect Error Logs",
      "action": "session.collectLogs",
      "params": { "tail": 100 },
      "dependsOn": ["check-status"]
    },
    {
      "id": "stop-session",
      "name": "Stop Failed Session",
      "action": "session.stop",
      "params": { "sessionId": "{{collect-logs.sessionId}}" },
      "dependsOn": ["collect-logs"]
    },
    {
      "id": "start-recovery-follow-up",
      "name": "Start Recovery Follow-up Session",
      "action": "session.start",
      "params": {
        "recovery": true,
        "prompt": "Investigate and recover after failed session {{collect-logs.sessionId}}."
      },
      "dependsOn": ["stop-session"]
    },
    {
      "id": "notify-operator",
      "name": "Notify Operator",
      "action": "notify.operator",
      "params": { "template": "session-recovered" },
      "dependsOn": ["start-recovery-follow-up"]
    }
  ]
}
