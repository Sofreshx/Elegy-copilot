{
  "name": "@elegy-copilot/root",
  "version": "0.0.0",
  "private": true,
  "description": "Elegy Copilot monorepo root",
  "license": "MIT",
  "workspaces": [
    "contracts",
    "copilot-ui",
    "local-tracker",
    "scripts"
  ],
  "scripts": {
    "postinstall": "npm run build:contracts",
    "build:contracts": "npm run build --workspace=contracts",
    "contracts:validate:session-state-sample": "node scripts/validate-session-state-canonical.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test:all": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1"
  },
  "devDependencies": {
    "mermaid": "^11.12.3",
    "vitepress": "^1.6.4"
  }
}
