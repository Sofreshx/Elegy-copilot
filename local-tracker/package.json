{
  "name": "@instruction-engine/local-tracker",
  "version": "0.1.0",
  "description": "Local agent tracker - watches for session/task changes and bridges to relay",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "dev:gateway": "ts-node src/messagingGateway/index.ts",
    "start": "node dist/index.js",
    "start:gateway": "node dist/messagingGateway/index.js",
    "watch": "tsc --watch",
    "test": "node scripts/test-with-ledger.js",
    "test:jest": "jest",
    "test:compliance": "jest --testPathPattern compliance --no-cache"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.2.0",
    "chokidar": "^4.0.0",
    "discord.js": "^14.0.0",
    "dockerode": "^4.0.6",
    "dotenv": "^16.4.7",
    "grammy": "^1.40.1",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.32",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
