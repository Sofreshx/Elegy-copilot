{
  "schemaVersion": "elegy-configuration-template/v1",
  "templateId": "elegy-copilot-spec-driven-overlays-template",
  "displayName": "Elegy Copilot Spec-Driven Overlays",
  "description": "Patch bounded spec-driven instruction overlays into repo-local instruction files.",
  "scope": "repo",
  "bindings": {
    "target.instructions": {
      "required": true,
      "description": "Repo-local instruction overlay file to patch."
    }
  },
  "operations": [
    {
      "operationType": "patchTextBlock",
      "operationId": "patch-copilot-instructions",
      "family": "instruction",
      "destination": {
        "base": "target-root",
        "path": ".github/copilot-instructions.md"
      },
      "startMarker": "<!-- elegy-copilot:begin spec-driven -->",
      "endMarker": "<!-- elegy-copilot:end spec-driven -->",
      "contentPath": {
        "base": "template-root",
        "path": "../assets/spec-driven-instructions.md"
      },
      "createIfMissing": true
    },
    {
      "operationType": "patchTextBlock",
      "operationId": "patch-surface-instructions",
      "family": "instruction",
      "destination": {
        "base": "target-root",
        "path": "${target.instructions}"
      },
      "startMarker": "<!-- elegy-copilot:begin spec-driven -->",
      "endMarker": "<!-- elegy-copilot:end spec-driven -->",
      "contentPath": {
        "base": "template-root",
        "path": "../assets/spec-driven-instructions.md"
      },
      "createIfMissing": true
    }
  ]
}
