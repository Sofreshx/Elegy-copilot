{
  "id": "finalization-validation",
  "name": "Finalization Validation",
  "description": "Validates a session finalization by checking PR status, test results, and documentation.",
  "version": "1.0.0",
  "steps": [
    {
      "id": "check-pr",
      "name": "Check PR Status",
      "action": "git.checkPrStatus"
    },
    {
      "id": "check-tests",
      "name": "Verify Test Results",
      "action": "session.checkTests"
    },
    {
      "id": "check-docs",
      "name": "Verify Documentation",
      "action": "session.checkDocs"
    },
    {
      "id": "generate-report",
      "name": "Generate Finalization Report",
      "action": "report.generate",
      "params": { "type": "finalization" },
      "dependsOn": ["check-pr", "check-tests", "check-docs"]
    },
    {
      "id": "notify-operator",
      "name": "Notify Operator",
      "action": "notify.operator",
      "params": { "template": "finalization-complete" },
      "dependsOn": ["generate-report"]
    }
  ]
}
