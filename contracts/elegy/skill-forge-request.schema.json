{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/skill-forge-request.schema.json",
  "title": "Skill Forge Request",
  "description": "Request to create a new skill via the SkillForge service.",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Kebab-case skill name."
    },
    "description": {
      "type": "string",
      "description": "Optional human-readable description of the skill."
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern"],
        "additionalProperties": false,
        "properties": {
          "pattern": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "description": "Patterns that trigger this skill."
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["constraintId", "required"],
        "additionalProperties": false,
        "properties": {
          "constraintId": { "type": "string" },
          "description": { "type": "string" },
          "required": { "type": "boolean" }
        }
      },
      "description": "Constraints applied to this skill."
    },
    "discoveryKeywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Keywords for skill discovery."
    }
  }
}
