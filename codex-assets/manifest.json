{
  "schemaVersion": 1,
  "package": {
    "name": "elegy-copilot-codex",
    "version": "0.1.0",
    "sourceCommitSha": "<REPLACE_WITH_GIT_SHA>"
  },
  "installDefaults": {
    "codexHome": "~/.codex",
    "agentsDir": "~/.codex/agents",
    "skillsDir": "~/.codex/skills",
    "instructionsFile": "~/.codex/AGENTS.md",
    "configFile": "~/.codex/config.toml",
    "description": "Home-installed Codex session assets for planning-first work, review, and minimal repository setup."
  },
  "installerHints": {
    "preferExplicitDestinations": true,
    "agentsAreFlat": true,
    "skillsRequireFolderName": true,
    "notes": "Install only Codex-native home instructions, a read-only reviewer agent, and the repo-setup skill under ~/.codex, then patch ~/.codex/config.toml conservatively. Do not bulk-install Copilot/engine assets into Codex."
  },
  "governance": {
    "g05": {
      "schemaVersion": "1.0.0",
      "requiredControls": {
        "early": [
          {
            "id": "safetyTokenParity",
            "owner": "Security Engineering"
          },
          {
            "id": "hookEnforcement",
            "owner": "Platform Engineering"
          },
          {
            "id": "telemetrySchemaValidation",
            "owner": "Observability Engineering"
          }
        ],
        "final": [
          {
            "id": "evidencePredicates",
            "owner": "Release Engineering"
          },
          {
            "id": "finalGateWaiverPrecedence",
            "owner": "Security Engineering"
          },
          {
            "id": "trustedEvidenceBindingRetention",
            "owner": "Release Engineering"
          }
        ]
      }
    }
  },
  "assets": [
    {
      "id": "codex-global-instructions",
      "type": "instructions",
      "source": "catalog-assets/instructions/agent-session-defaults.md",
      "destination": "agent-session-defaults.md",
      "appendix": "codex-assets/home/AGENTS-appendix.md"
    },
    {
      "id": "codex-reviewer-agent",
      "type": "agent",
      "source": "codex-assets/agents/reviewer.toml",
      "destination": "agents/reviewer.toml"
    },
    {
      "id": "codex-repo-setup-skill",
      "type": "skill",
      "source": "codex-assets/skills/repo-setup",
      "destination": "skills/repo-setup"
    },
    {
      "id": "codex-skill-discovery-skill",
      "type": "skill",
      "source": "engine-assets/skills/skill-discovery",
      "destination": "skills/skill-discovery",
      "loadMode": "always"
    },
    {
      "id": "codex-rubberduck-plan-review-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/rubberduck-plan-review",
      "destination": "skills/rubberduck-plan-review",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-implementation-review-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/implementation-review",
      "destination": "skills/implementation-review",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-implementation-handoff-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/implementation-handoff",
      "destination": "skills/implementation-handoff",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-spec-dev-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/spec-dev",
      "destination": "skills/spec-dev",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-spec-authoring-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/spec-authoring",
      "destination": "skills/spec-authoring",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-spec-review-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/spec-review",
      "destination": "skills/spec-review",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-spec-planning-bridge-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/spec-planning-bridge",
      "destination": "skills/spec-planning-bridge",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-elegy-planning-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/elegy-planning",
      "destination": "skills/elegy-planning",
      "loadMode": "always"
    },
    {
      "id": "codex-repo-backed-obsidian-docs-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/repo-backed-obsidian-docs",
      "destination": "skills/repo-backed-obsidian-docs",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-ui-system-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/ui-system",
      "destination": "skills/ui-system",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-ui-design-spec-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/ui-design-spec",
      "destination": "skills/ui-design-spec",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-ui-visual-review-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/ui-visual-review",
      "destination": "skills/ui-visual-review",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-commit-check-setup-skill",
      "type": "skill",
      "source": "engine-assets/skills/commit-check-setup",
      "destination": "skills/commit-check-setup",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-skill-authoring-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/skill-authoring",
      "destination": "skills/skill-authoring",
      "loadMode": "on-demand"
    },
    {
      "id": "codex-agents-md-authoring-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/agents-md-authoring",
      "destination": "skills/agents-md-authoring",
      "loadMode": "on-demand"
    }
  ],
  "sourcePatterns": []
}
