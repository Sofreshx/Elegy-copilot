{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elegy/contracts/formalization/1.0.0/monitoring-event.schema.json",
  "title": "AgenticEvent",
  "description": "Canonical agentic monitoring event contract for non-.NET consumers.",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "timestamp", "entityKind", "entityId", "category", "severity", "message"],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "entityKind": {
      "type": "string",
      "enum": ["skill", "agent", "dynamicSkill"]
    },
    "entityId": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": ["lifecycle", "activation", "validation", "routing"]
    },
    "severity": {
      "type": "string",
      "enum": ["trace", "info", "warning", "error", "critical"]
    },
    "message": { "type": "string" },
    "metadata": {
      "type": ["object", "null"],
      "additionalProperties": { "type": "string" }
    }
  }
}
