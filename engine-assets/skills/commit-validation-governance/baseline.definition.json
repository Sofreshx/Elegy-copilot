{
  "schemaVersion": 1,
  "baselineKey": "commit-validation-governance",
  "baselineVersion": "1.0.0",
  "mode": "audit-propose-only",
  "authority": {
    "canonicalDocPath": "docs/system/commit-validation-governance.md",
    "definitionPath": "engine-assets/skills/commit-validation-governance/baseline.definition.json",
    "projectionPath": "engine-assets/skills/commit-validation-governance/baseline.json",
    "configSchemaPath": "engine-assets/skills/commit-validation-governance/config.schema.json"
  },
  "configSchemaVersion": 3,
  "defaultProfile": "commit",
  "passFailAuthority": "selected blocking lanes",
  "scoreRole": "diagnostic",
  "normativeLaneSet": {
    "required": ["test", "lint", "format", "typecheck"],
    "recommended": ["coverage"]
  },
  "defaultWeights": {
    "test": 0.30,
    "lint": 0.20,
    "format": 0.10,
    "stylelint": 0.05,
    "typecheck": 0.25,
    "build-contracts": 0.05,
    "build-ui": 0.05
  },
  "defaultGates": [],
  "defaultThreshold": 70,
  "detectableLanguages": ["typescript", "rust"],
  "detectionRules": {
    "typescript": {
      "packageJsonIndicators": true,
      "configFileIndicators": ["tsconfig.json", ".eslintrc*", "eslint.config.*", ".prettierrc*", "jest.config.*", "vitest.config.*"]
    },
    "rust": {
      "cargoTomlIndicators": true,
      "workspaceMembers": true
    }
  }
}
