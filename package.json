{
  "name": "@elegy-copilot/root",
  "version": "0.0.0",
  "private": true,
  "description": "Elegy Copilot monorepo root",
  "license": "MIT",
  "workspaces": [
    "contracts",
    "copilot-ui",
    "local-tracker",
    "scripts"
  ],
  "scripts": {
    "changeset": "changeset",
    "changeset:version": "changeset version",
