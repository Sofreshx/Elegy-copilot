# Cloud Relay Service Configuration
# Copy this file to .env and update values

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# JWT Configuration
# IMPORTANT: Change this in production! Use a strong random secret.
# Generate with: openssl rand -base64 64
JWT_SECRET=your-secret-key-change-in-production
JWT_ISSUER=instruction-engine-relay
JWT_AUDIENCE=instruction-engine

# Authentication
# Set to false for local development without auth
REQUIRE_AUTH=true

# Message Size Limits
# Maximum message size in bytes (default: 1MB)
MAX_MESSAGE_SIZE=1048576
