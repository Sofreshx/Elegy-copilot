{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./session-start.sh",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "./session-end.sh",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./log-prompt.sh",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "./pre-tool-use.sh",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "./post-tool-use.sh",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "./error-occurred.sh",
        "cwd": "scripts/hooks",
        "timeoutSec": 10
      }
    ]
  }
}
