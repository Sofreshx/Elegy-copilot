{
  "name": "@elegy-copilot/local-repo-mcp",
  "version": "0.1.0",
  "description": "OAuth-protected read-only local repo MCP server for ChatGPT Web.",
  "license": "MIT",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "jose": "^5.10.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.21",
    "typescript": "^5.8.2"
  }
}
