{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://instruction-engine.dev/schemas/waiver.schema.json",
  "title": "Instruction Engine Policy Waiver",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "waiverId",
    "policyVersion",
    "controls",
    "issuedAt",
    "expiresAt",
    "reason",
    "signature"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "waiverId": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]{2,127}$"
    },
    "policyVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": "string",
      "minLength": 8
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "keyId",
        "value"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "hmac-sha256"
          ]
        },
        "keyId": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      }
    }
  }
}
