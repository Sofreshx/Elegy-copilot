{
  "schemaVersion": 1,
  "package": {
    "name": "instruction-engine-opencode",
    "version": "0.1.0",
    "sourceCommitSha": "<REPLACE_WITH_GIT_SHA>"
  },
  "installDefaults": {
    "opencodeHome": "~/.config/opencode",
    "agentsDir": "~/.config/opencode/agents",
    "skillsDir": "~/.config/opencode/skills",
    "instructionsFile": "~/.config/opencode/AGENTS.md",
    "description": "Native-first OpenCode instructions plus curated planning, roadmap, review, security, and governance skills. Kept intentionally minimal to complement OpenCode's built-in harness."
  },
  "governance": {
    "g05": {
      "schemaVersion": "1.0.0",
      "requiredControls": {
        "early": [
          {
            "id": "safetyTokenParity",
            "owner": "Security Engineering"
          },
          {
            "id": "hookEnforcement",
            "owner": "Platform Engineering"
          },
          {
            "id": "telemetrySchemaValidation",
            "owner": "Observability Engineering"
          }
        ],
        "final": [
          {
            "id": "evidencePredicates",
            "owner": "Release Engineering"
          },
          {
            "id": "finalGateWaiverPrecedence",
            "owner": "Security Engineering"
          },
          {
            "id": "trustedEvidenceBindingRetention",
            "owner": "Release Engineering"
          }
        ]
      }
    }
  },
  "assets": [
    {
      "id": "opencode-global-instructions",
      "type": "instructions",
      "source": "opencode-assets/home/AGENTS.md",
      "destination": "AGENTS.md"
    },
    {
      "id": "opencode-skill-discovery-skill",
      "type": "skill",
      "source": "engine-assets/skills/skill-discovery",
      "destination": "skills/skill-discovery",
      "loadMode": "always"
    },
    {
      "id": "opencode-elegy-skills-discovery-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/elegy-skills-discovery",
      "destination": "skills/elegy-skills-discovery",
      "loadMode": "always"
    },
    {
      "id": "opencode-elegy-planning-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/elegy-planning",
      "destination": "skills/elegy-planning",
      "loadMode": "always"
    },
    {
      "id": "opencode-rubberduck-plan-review-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/rubberduck-plan-review",
      "destination": "skills/rubberduck-plan-review",
      "loadMode": "on-demand"
    },
    {
      "id": "opencode-roadmap-planning-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/roadmap-planning",
      "destination": "skills/roadmap-planning",
      "loadMode": "on-demand"
    },
    {
      "id": "opencode-implementation-review-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/implementation-review",
      "destination": "skills/implementation-review",
      "loadMode": "on-demand"
    },
    {
      "id": "opencode-implementation-handoff-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/implementation-handoff",
      "destination": "skills/implementation-handoff",
      "loadMode": "on-demand"
    },
    {
      "id": "opencode-spec-dev-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/spec-dev",
      "destination": "skills/spec-dev",
      "loadMode": "on-demand"
    },
    {
      "id": "opencode-spec-authoring-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/spec-authoring",
      "destination": "skills/spec-authoring",
      "loadMode": "on-demand"
    },
    {
      "id": "opencode-spec-review-skill",
      "type": "skill",
      "source": "catalog-assets/shared-skills/spec-review",
      "destination": "skills/spec-review",
      "loadMode": "on-demand"
    },
    {
      "id": "opencode-code-review-skill",
      "type": "skill",
      "source": "opencode-assets/skills/code-review",
      "destination": "skills/code-review"
    },
    {
      "id": "opencode-security-skill",
      "type": "skill",
      "source": "opencode-assets/skills/security",
      "destination": "skills/security"
    },
    {
      "id": "opencode-project-conventions-governance-skill",
      "type": "skill",
      "source": "opencode-assets/skills/project-conventions-governance",
      "destination": "skills/project-conventions-governance"
    },
    {
      "id": "opencode-stack-detector-skill",
      "type": "skill",
      "source": "opencode-assets/skills/stack-detector",
      "destination": "skills/stack-detector"
    },
    {
      "id": "opencode-worktree-plugin",
      "type": "plugin",
      "source": "opencode-assets/plugins/worktree.js",
      "destination": "plugins/worktree.js"
    },
    {
      "id": "opencode-worktree-skill",
      "type": "skill",
      "source": "opencode-assets/skills/worktree",
      "destination": "skills/worktree"
    }
  ],
  "sourcePatterns": []
}
